<launch>
  <!--机器人的电池容量 -->
  <param name="robot_BatteryCapacity" value="5000"/>

  <!-- turn on base_serial 开启底层单片机的控制节点  -->
  <include file="$(find robot)/launch/include/base_serial.launch">
  </include>

  <!-- 发布用于建图、导航的TF关系与小车外形可视化 -->
    <include file="$(find robot)/launch/tf_robot.launch">
    </include>
  
</launch>
